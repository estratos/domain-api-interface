{
    "name": "estratos/domain-api-interface",
    "type": "symfony-bundle",
    "description": "Domain API Interface Bundle - Common contracts for domain registrar providers",
    "keywords": [
        "symfony",
        "bundle",
        "domain",
        "registrar",
        "interface",
        "contract",
        "api",
        "dns"
    ],
    "license": "MIT",
    "authors": [
        {
            "name": "Julio Rodriguez",
            "email": "julio.stratos@gmail.com",
            "role": "Lead Developer"
        }
    ],
    "require": {
        "php": ">=8.3",
        "symfony/framework-bundle": "^7.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5",
        "phpstan/phpstan": "^1.10",
        "friendsofphp/php-cs-fixer": "^3.49"
    },
    "autoload": {
        "psr-4": {
            "Estratos\\DomainApiInterface\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Estratos\\DomainApiInterface\\Tests\\": "tests/"
        }
    },
    "config": {
        "sort-packages": true,
        "optimize-autoloader": true,
        "preferred-install": "dist"
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "scripts": {
        "phpstan": "phpstan analyse src tests --level=max",
        "php-cs-fixer": "php-cs-fixer fix --dry-run --diff",
        "php-cs-fixer-fix": "php-cs-fixer fix",
        "test": "phpunit"
    }
}
